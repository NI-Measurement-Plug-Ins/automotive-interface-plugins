				</modIO>
			</targetIO>

			<folder name="PXI">
				<targetIO>
					<addIO>
						<resource name="PXI/Sync100"/>
					</addIO>
				</targetIO>
			</folder>

			<folder name="FIFOs">
				<folder name="Display FIFOs">
					<FIFO name="Display 0 Image Metadata">
